<?xml version="1.0" ?>
<component xsdVersion="2.0" name="PatternGen_F16_TLE987" displayName="PatternGen" library="Ifx_MHA" multiInstance="true" includes="" compVersion="1.3.0" libraryVersion="1.3.0">
   <param name="deadTime" symbolName="CFG_DEADTIME" displayName="Dead time" index="0x3000" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="uint16_t" dataTypeTU="uint16_t" dataTypePU="double" decimalPlaces="2" step="0.05" physicalUnit="us" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="1" generatePattern="configDefine">
      <description>This configures the value of the HighSide-LowSide switching Dead time. Dead time min value is defined by parameter Minimum dead time.</description>
      <targetEvent getValueDU="Ifx_MHA_PatternGen_F16_TLE987_getDeadTime_ns" setValueDU="Ifx_MHA_PatternGen_F16_TLE987_setDeadTime_ns"/>
      <defaultDU>500</defaultDU>
      <defaultPU>0.5</defaultPU>
      <minDU>50</minDU>
      <maxDU>2000</maxDU>
      <minPU>0.05</minPU>
      <maxPU>2.0</maxPU>
   </param>
   <param name="frequency" symbolName="CFG_FREQUENCY_KHZ" displayName="PWM frequency" dynamicConfig="false" staticConfig="true" dataTypeDU="uint16_t" dataTypeTU="uint16_t" dataTypePU="uint16_t" decimalPlaces="0" step="1" physicalUnit="kHz" accessMode="readWrite" changeWhileMotorRunning="false" isPartOfParSet="false" isPartOfParDownload="false" userLevel="1" generatePattern="configDefine">
