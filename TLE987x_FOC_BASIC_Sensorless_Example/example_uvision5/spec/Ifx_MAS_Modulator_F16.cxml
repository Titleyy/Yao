   <param name="maxAmplitude" symbolName="maxAmplitudeQ15" displayName="Modulator max. output voltage" index="0x4006" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="int16_t" dataTypePU="double" decimalPlaces="2" step="0.01" physicalUnit="%" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="0" generatePattern="paramInStruct">
      <description>This configures the max. output voltage of the modulator. Unit is in percent of baseVoltage</description>
