      <minPU>0</minPU>
      <maxPU>5.0</maxPU>
   </param>
   <param name="deadTime" symbolName="deadTime_tick" displayName="Dead time" index="0x4001" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="uint16_t" dataTypePU="double" decimalPlaces="2" step="0.05" physicalUnit="us" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="1" generatePattern="paramInStruct">
