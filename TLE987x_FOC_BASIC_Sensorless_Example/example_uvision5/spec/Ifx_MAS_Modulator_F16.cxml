   <param name="biDirectionalShiftingThresholdHigh" symbolName="biDirectionalShiftingThresholdHighQ15" displayName="Transition threshold high" index="0x4007" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="int16_t" dataTypePU="double" decimalPlaces="2" step="0.01" physicalUnit="%" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="1" generatePattern="paramInStruct">
      <description>High transition from bidirectional two phase to bidirectional three phase shifting, should be greater or equal to the low transition value</description>
