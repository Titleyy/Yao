      <maxDU>1</maxDU>
      <minPU>0</minPU>
      <maxPU>1</maxPU>
   </param>
   <param name="error_overmodulationFlag" symbolName="p_status.overmodulationFlag" displayName="Over modulation flag" index="0x4013" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="bool" dataTypeTU="bool" dataTypePU="bool" decimalPlaces="0" step="1" accessMode="readOnly" generatePattern="memberInSelfStruct">
      <description>Error status flag. Is set when over modulation is reached.</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <minDU>0</minDU>
      <maxDU>1</maxDU>
      <minPU>0</minPU>
      <maxPU>1</maxPU>
   </param>
   <param name="compareValues" symbolName="p_output.compareValues_tick" displayName="Output PWM timer compare values" index="0x4014" dynamicConfig="false" staticConfig="false" subIndexCount="6" dataTypeDU="uint16_t" dataTypeTU="uint16_t" dataTypePU="uint16_t" decimalPlaces="0" step="1" physicalUnit="ticks" accessMode="readOnly" userLevel="2" generatePattern="memberInSelfStruct">
      <!-- This PDO is an array and currently still not support by ParamTable. dynamicConfig is false to hide this parameter -->
      <description>The timer compare values for the CCU phase switches (HS), separated for up-counting and for down-counting on each phase, total of six signals, in timer ticks:
index 0: phase U, up-counting
index 1: phase V, up-counting
index 2: phase W, up-counting
index 3: phase U, down-counting
index 4: phase V, down-counting
index 5: phase W, down-counting</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>2000</defaultDU>
      <defaultPU>2000</defaultPU>
      <minDU>0</minDU>
      <maxDU>65535</maxDU>
      <minPU>0</minPU>
      <maxPU>65535</maxPU>
   </param>
   <param name="triggerTime" symbolName="p_output.triggerTime_tick" displayName="Output current measurement trigger time" index="0x4015" dynamicConfig="false" staticConfig="false" subIndexCount="2" dataTypeDU="uint16_t" dataTypeTU="uint16_t" dataTypePU="uint16_t" decimalPlaces="0" step="1" physicalUnit="ticks" accessMode="readOnly" userLevel="2" generatePattern="memberInSelfStruct">
      <!-- This PDO is an array and currently still not support by ParamTable. dynamicConfig is false to hide this parameter -->
      <description>This output contains the timer values for current measurement events. For single-shunt scheme, the modulator calculates the values for trigger time 1 and trigger timer 2 to meet one of the following conditions:
- case A:
- trigger timer 1 is within a pulse where a phase X is active. X is any phase of U, V or W.
- trigger timer 2 is within the pulse where two phases are active. One of the two phases is phase X.
- case B:
- trigger timer 1 is within a pulse where a phase X is active. X is any phase of U, V or W.
- trigger timer 2 is within the pulse where another phase is active.
The trigger timer 1 and trigger timer 2 are the tick count starting from zero match.</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>2</defaultDU>
      <defaultPU>2</defaultPU>
      <minDU>0</minDU>
      <maxDU>65535</maxDU>
      <minPU>0</minPU>
      <maxPU>65535</maxPU>
   </param>
   <param name="actualVoltageAmplitude" symbolName="p_output.actualVoltage.amplitude" displayName="Output actual voltage amplitude" index="0x4016" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="int16_t" dataTypePU="double" decimalPlaces="2" step="0.01" physicalUnit="V" accessMode="readOnly" generatePattern="memberInSelfStruct">
      <description>This output represents the amplitude of the resulting voltage space vector in polar coordinates. Range: [0; upper limit], where the &quot;upper limit&quot; is the minimum of the following:
- Maximum amplitude
- The value of the reference voltage at which overmodulation occurs which depends on the input dcLinkVoltage_V as follows: Uref_overmod = 0.907 * 2 / pi * dcLinkVoltage_V</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <minDU>-32767</minDU>
      <maxDU>32767</maxDU>
      <minPU>-24</minPU>
      <maxPU>24</maxPU>
   </param>
   <param name="actualVoltageAngle" symbolName="p_output.actualVoltage.angle" displayName="Output actual voltage angle" index="0x4017" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="uint32_t" dataTypeTU="uint32_t" dataTypePU="double" decimalPlaces="4" step="0.0001" physicalUnit="rad" accessMode="readOnly" generatePattern="memberInSelfStruct">
      <description>This output represents the angle of the resulting voltage space vector in polar coordinates. This is equal to the input reference voltage angle. 0xFFFFFFFF = 2*pi = 360degree</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <minDU>0</minDU>
      <maxDU>4294967295</maxDU>
      <minPU>0</minPU>
      <maxPU>6.2832</maxPU>
   </param>
   <param name="currentReconstructionInfoSector" symbolName="p_output.currentReconstructionInfo.sector" displayName="Output current reconstruction info sector" index="0x4018" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="uint8_t" dataTypeTU="uint8_t" dataTypePU="uint8_t" decimalPlaces="0" step="1" accessMode="readOnly" generatePattern="memberInSelfStruct">
      <description>This output contains the sector number which is needed for current reconstruction, with range between 0 and 5</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <minDU>0</minDU>
      <maxDU>5</maxDU>
      <minPU>0</minPU>
      <maxPU>5</maxPU>
   </param>
   <param name="currentReconstructionInfoSecondTriggerIsSum" symbolName="p_output.currentReconstructionInfo.secondTriggerIsSum" displayName="Output current reconstruction info second trigger is sum" index="0x4019" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="bool" dataTypeTU="bool" dataTypePU="bool" decimalPlaces="0" step="1" accessMode="readOnly" userLevel="2" generatePattern="memberInSelfStruct">
      <description>This output contains the flag to identify whether the second current trigger is during the period where two phases are active (case A), during the period where only one phase is active (case B)</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>1</defaultDU>
      <defaultPU>1</defaultPU>
      <minDU>0</minDU>
      <maxDU>1</maxDU>
      <minPU>0</minPU>
      <maxPU>1</maxPU>
   </param>
</component>
