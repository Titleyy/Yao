      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <enumEntry name="bidirectionalTwoPhase" value="0"/>
      <enumEntry name="bidirectionalThreePhase" value="1"/>
   </param>
   <param name="error_maxAmplitudeFlag" symbolName="p_status.maxAmplitudeFlag" displayName="Max amplitude flag" index="0x4012" dynamicConfig="true" staticConfig="false" subIndexCount="0" dataTypeDU="bool" dataTypeTU="bool" dataTypePU="bool" decimalPlaces="0" step="1" accessMode="readOnly" generatePattern="memberInSelfStruct">
      <description>Error status flag. Is set when max amplitude is reached.</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
