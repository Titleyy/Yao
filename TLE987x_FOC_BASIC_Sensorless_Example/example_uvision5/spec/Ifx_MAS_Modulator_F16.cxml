      <enumEntry name="Active Short High Low" value="2"/>
   </param>
   <param name="faultReactionMaxAmplitude" symbolName="CFG_FAULT_REACTION_MAX_AMPLITUDE" displayName="Fault reaction on max amplitude reached" dynamicConfig="false" staticConfig="true" subIndexCount="0" dataTypeDU="uint8_t" dataTypeTU="uint8_t" dataTypePU="uint8_t" decimalPlaces="0" step="1" accessMode="readWrite" changeWhileMotorRunning="false" isPartOfParSet="false" isPartOfParDownload="false" userLevel="1" generatePattern="configDefine">
      <description>Fault reaction on max amplitude reached condition. </description>
