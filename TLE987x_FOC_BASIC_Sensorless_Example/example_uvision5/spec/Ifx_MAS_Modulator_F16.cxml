      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <enumEntry name="Active Short Low" value="0"/>
      <enumEntry name="Active Short High" value="1"/>
      <enumEntry name="Active Short High Low" value="2"/>
   </param>
   <param name="faultOutBehavior" symbolName="CFG_FAULT_OUT_BEHAVIOR" displayName="Fault output behavior" dynamicConfig="false" staticConfig="true" subIndexCount="0" dataTypeDU="uint8_t" dataTypeTU="uint8_t" dataTypePU="uint8_t" decimalPlaces="0" step="1" accessMode="readWrite" changeWhileMotorRunning="false" isPartOfParSet="false" isPartOfParDownload="false" userLevel="1" generatePattern="configDefine">
      <description>When the modulator reacts on a fault one of three fault behaviors can be selected. So this fault behavior is only used in case a fault reaction is set to Report and react.</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>0</defaultDU>
      <defaultPU>0</defaultPU>
      <enumEntry name="Active Short Low" value="0"/>
