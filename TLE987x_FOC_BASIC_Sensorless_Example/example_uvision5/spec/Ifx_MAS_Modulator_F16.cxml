   <param name="biDirectionalShiftingThresholdLow" symbolName="biDirectionalShiftingThresholdLowQ15" displayName="Transition threshold low" index="0x4008" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="int16_t" dataTypePU="double" decimalPlaces="2" step="0.01" physicalUnit="%" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="1" generatePattern="paramInStruct">
      <description>Low transition from bidirectional two phase to bidirectional three phase shifting, should be less than or equal to the high transition value</description>
