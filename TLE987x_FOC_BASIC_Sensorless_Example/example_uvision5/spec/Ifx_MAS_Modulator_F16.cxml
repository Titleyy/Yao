      <enumEntry name="Report and React" value="3"/>
   </param>
   <param name="faultReactionOvermodulation" symbolName="CFG_FAULT_REACTION_OVERMODULATION" displayName="Fault reaction on overmodulation" dynamicConfig="false" staticConfig="true" subIndexCount="0" dataTypeDU="uint8_t" dataTypeTU="uint8_t" dataTypePU="uint8_t" decimalPlaces="0" step="1" accessMode="readWrite" changeWhileMotorRunning="false" isPartOfParSet="false" isPartOfParDownload="false" userLevel="1" generatePattern="configDefine">
      <description>Fault reaction on overmodulation reached condition.</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>1</defaultDU>
      <defaultPU>1</defaultPU>
      <enumEntry name="Disable" value="0"/>
      <enumEntry name="Enable" value="1"/>
      <enumEntry name="Report Only" value="2"/>
      <enumEntry name="Report and React" value="3"/>
   </param>
   <param name="enableFaultOut" symbolName="CFG_ENABLE_FAULT_OUT" displayName="Enable fault user callback" dynamicConfig="false" staticConfig="true" subIndexCount="0" dataTypeDU="bool" dataTypeTU="bool" dataTypePU="bool" decimalPlaces="0" step="1" accessMode="readWrite" changeWhileMotorRunning="false" isPartOfParSet="false" isPartOfParDownload="false" userLevel="1" generatePattern="configDefine">
      <description>This enables or disables a fault user callback</description>
