      <description>Beta lowpass cut-off frequency</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>160000</defaultDU>
      <defaultPU>16</defaultPU>
      <minDU>0</minDU>
      <maxDU>2147480000</maxDU>
      <minPU>0</minPU>
      <maxPU>214748</maxPU>
   </param>
   <param name="speedCutoff" symbolName="CFG_SPEED_CUTOFF_HZ" displayName="Base current" dynamicConfig="false" staticConfig="true" subIndexCount="0" dataTypeDU="uint32_t" dataTypeTU="uint32_t" dataTypePU="double" decimalPlaces="4" step="0.0001" physicalUnit="Hz" accessMode="readOnly" changeWhileMotorRunning="false" isPartOfParSet="true" isPartOfParDownload="false" userLevel="1" generatePattern="none">
      <description>Base current  is used for normalization</description>
      <targetEvent getValueDU="NULL" setValueDU="NULL"/>
      <defaultDU>160000</defaultDU>
      <defaultPU>16</defaultPU>
      <minDU>0</minDU>
