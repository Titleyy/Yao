      <maxPU>100</maxPU>
   </param>   
   <param name="cornerVolt" symbolName="VToFLUTnorm.cornerVoltQ15" displayName="Voltage at corner speed" index="0x4403" dynamicConfig="true" staticConfig="true" subIndexCount="0" dataTypeDU="int16_t" dataTypeTU="uint16_t" dataTypePU="double" decimalPlaces="2" step="0.01" physicalUnit="%" accessMode="readWrite" changeWhileMotorRunning="true" isPartOfParSet="true" isPartOfParDownload="true" userLevel="0" generatePattern="paramInStruct">
