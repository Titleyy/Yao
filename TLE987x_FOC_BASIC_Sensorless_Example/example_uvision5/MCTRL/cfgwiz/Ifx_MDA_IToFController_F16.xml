<?xml version="1.0" encoding="UTF-8"?>
<ifxmlcfg version="2.7.0">
    <checksum>cbffd107527e6f9e4219127f6c2e71db9a49ac434508e49d4e98b86cb01f83bd</checksum>
    <version label="V2.0.0"/>
    <header file="Ifx_MDA_IToFController_F16_Cfg.h" fullname="1"/>
    <!--********************************************************************************-->
    <!--                                      I/F                                       -->
    <!--********************************************************************************-->    
    <treecontainer headerlabels="Structure;Settings;" label="I/f" desc="I/f Parameters" columnwidths="450;250">
        <spinbox label="Sampling time" suffix=" us" define="IFX_MDA_ITOFCONTROLLER_F16_CFG.SAMPLING_TIME_US" default="50" range="25;10000"/>

        <!-- Limit the base speed according to the sampling time and data type of Angle increment -->
        <math define="IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_SPEED_RADPS_MAX" formula="6.283185307179586*1000000/IFX_MDA_ITOFCONTROLLER_F16_CFG.SAMPLING_TIME_US" visible="false">
            <action event="changed" cmd="setDef" data="IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_SPEED_RADPS.max=IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_SPEED_RADPS_MAX"/>
        </math>

        <spinbox label="Base electrical speed" suffix=" rad/s" define="IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_SPEED_RADPS" header="Ifx_MDA_IToFController_F16_Cfg.h" default="12000" range="1;32000"/>
        <doublespinbox label="Base current" suffix=" A" define="IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_A" header="Ifx_MDA_IToFController_F16_Cfg.h" default="20.00000" range="1;32000"/>

        <!-- set the maximum parameter = base value and limit the Q15 to 32767 -->
        <math define="IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_TEMP" formula="(32767/32768)*IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_A" visible="false">
            <action event="changed" cmd="setDef" data="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_REAL_A.max=IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_TEMP"/>
            <action event="changed" cmd="setDef" data="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_IMAG_A.max=IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_TEMP"/>
        </math>
        
        <doublespinbox label="Real Current" suffix=" A" define="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_REAL_A" default="4.00000" />
        <math define="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_REAL_N" formula="floor(IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_REAL_A/IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_A*2^15)" header="Ifx_MDA_IToFController_F16_Cfg.h" visible="false" />

        <doublespinbox label="Imaginary Current" suffix=" A" define="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_IMAG_A" default="0.00000" />
        <math define="IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_IMAG_N" formula="floor(IFX_MDA_ITOFCONTROLLER_F16_CFG.REF_CURRENT_IMAG_A/IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_CURRENT_A*2^15)" header="Ifx_MDA_IToFController_F16_Cfg.h" visible="false" />

        <math define="IFX_MDA_ITOFCONTROLLER_F16_CFG.ANGLE_INC_Q14" formula="floor(IFX_MDA_ITOFCONTROLLER_F16_CFG.SAMPLING_TIME_US*IFX_MDA_ITOFCONTROLLER_F16_CFG.BASE_SPEED_RADPS*16384/(1000000.0*6.283185307179586))" header="Ifx_MDA_IToFController_F16_Cfg.h" visible="false" />
    </treecontainer>
</ifxmlcfg>